# Application
DEBUG=false
ENVIRONMENT=production

# CORS — add your Vercel frontend URL here after deploying
CORS_ORIGINS=["http://localhost:3000","https://your-app.vercel.app"]

# ── LLM ──────────────────────────────────────────────────────────────────────
# Set LLM_PROVIDER=groq for cloud deployment, ollama for local dev
LLM_PROVIDER=groq

# Groq (cloud) — get free key at https://console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (local dev only)
OLLAMA_BASE_URL=http://ollama:11434
LLM_MODEL=qwen2.5-coder:7b

LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ── Qdrant ───────────────────────────────────────────────────────────────────
# Cloud: set QDRANT_URL + QDRANT_API_KEY (https://cloud.qdrant.io — free tier)
# Local: leave QDRANT_URL blank, set QDRANT_HOST=qdrant QDRANT_PORT=6333
QDRANT_URL=https://xxxx.us-east4-0.gcp.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ── Redis ─────────────────────────────────────────────────────────────────────
# Cloud: Upstash Redis URL (https://upstash.com — free tier)
# Local: redis://redis:6379
REDIS_URL=rediss://default:your-password@your-endpoint.upstash.io:6379

# ── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384

# ── GitHub (optional — needed for private repos) ─────────────────────────────
GITHUB_TOKEN=

# ── Storage ───────────────────────────────────────────────────────────────────
REPOS_BASE_DIR=/tmp/repos
MAX_REPO_SIZE_MB=500
